# Ye file copy karke naam ".env" rakh dena, aur apni real values daalna

# Session ko secure karne ke liye random secret (koi bhi lambi random string)
SESSION_SECRET=change_this_to_a_random_long_string

# AES-256 encryption key - EXACTLY 32 characters honi chahiye
ENCRYPTION_KEY=12345678901234567890123456789012

# Google OAuth 2.0 credentials (Google Cloud Console se free milte hain)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

PORT=3000
